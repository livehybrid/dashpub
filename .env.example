# =============================================================================
# Splunk Connection (Required)
# =============================================================================

# Full REST API URL — if set, SPLUNKD_HOST/PORT/PROTOCOL are ignored
SPLUNKD_URL=https://your-splunk-instance:8089

# Alternative to SPLUNKD_URL — individual components
# SPLUNKD_HOST=your-splunk-instance
# SPLUNKD_PORT=8089
# SPLUNKD_PROTOCOL=https

# Authentication: use token OR username+password (token takes priority)
SPLUNKD_TOKEN=your-api-token
# SPLUNKD_USER=admin
# SPLUNKD_PASSWORD=your_password

# Splunk UI settings (for fetching static dashboard assets)
SPLUNKD_UI_PORT=8000
SPLUNKD_LOCALE=en-US

# =============================================================================
# CLI / Init Automation
# =============================================================================

# Splunk app containing your dashboards
DASHPUB_APP=your-splunk-app

# Comma-separated list of dashboards and their category tags
# Format: name[Category|Tag],name2[Category]
# DASHPUB_DASHBOARDS=my_dashboard[Demo|Category],another[Monitoring]

# Path to a JSON config file (alternative to individual env vars)
# DASHPUB_CONFIGFILE=./dashpub.config.json

# Output directory name (default: app)
DASHPUB_FOLDERNAME=app

# Vercel project name
# DASHPUB_PROJECTNAME=my-dashpub

# Git repo URL included in generated package.json
# DASHPUB_REPO=https://github.com/yourusername/dashpub

# Deployed public URL of the application
# DASHPUB_URL=https://dashboards.example.com

# Fully-qualified domain name for asset URI rewriting
# DASHPUB_FQDN=dashboards.example.com

# =============================================================================
# Application Display Settings
# =============================================================================

# Page title
DASHPUB_TITLE=My Dashboards
NEXT_PUBLIC_DASHPUBTITLE=My Dashboards

# UI theme (light or dark)
# DASHPUB_THEME=light

# Footer text
# DASHPUB_FOOTER=Hosted Splunk Dashboards
NEXT_PUBLIC_DASHPUBFOOTER=Hosted Splunk Dashboards

# Hosted-by attribution
NEXT_PUBLIC_DASHPUBHOSTEDBY=Your Company
NEXT_PUBLIC_DASHPUBHOSTEDURL=https://yourcompany.com
# DASHPUB_HOSTEDBY_URL=https://yourcompany.com

# Repository link
NEXT_PUBLIC_DASHPUBREPO=https://github.com/yourusername/dashpub

# =============================================================================
# Screenshots
# =============================================================================

# Enable dashboard thumbnail screenshots
DASHPUB_SCREENSHOTS=false
NEXT_PUBLIC_DASHPUBSCREENSHOTS=false

# Base URL where screenshots are hosted (leave empty to use relative paths)
NEXT_PUBLIC_BASE_SCREENSHOT_URL=

# Screenshot directory name (default: screenshots)
DASHPUB_SCREENSHOT_DIR=screenshots
NEXT_PUBLIC_DASHPUBSCREENSHOTDIR=screenshots

# Screenshot file extension (default: png)
DASHPUB_SCREENSHOT_EXT=png
NEXT_PUBLIC_DASHPUBSCREENSHOTEXT=png

# =============================================================================
# Authentication & Security
# =============================================================================

# Require JWT authentication for dashboard access
JWT_REQUIRED=false

# JWT secret (change to a strong random value in production)
JWT_SECRET=your-secret-key-change-in-production

# JWT expiry
JWT_EXPIRES_IN=24h

# Default credentials for JWT login endpoint
# JWT_USERNAME=admin
# JWT_PASSWORD=your_password

# API key header name
API_KEY_HEADER=X-API-Key

# Cache management key (protects DELETE /api/cache/* endpoints)
# CACHE_MANAGEMENT_KEY=your-secure-random-key

# =============================================================================
# Performance & Rate Limiting
# =============================================================================

# Rate limit window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per rate limit window
RATE_LIMIT_MAX_REQUESTS=1000

# Maximum retry attempts for Splunk API calls
MAX_RETRIES=3

# Delay between search job polls (milliseconds)
SEARCH_JOB_DELAY_MS=250

# Minimum dashboard refresh time (seconds)
MIN_REFRESH_TIME=60

# =============================================================================
# Deployment
# =============================================================================

# Vercel deployment mode (y/n)
DASHPUB_VERCEL=n

# Vercel URL (auto-set by Vercel)
# VERCEL_URL=your-app.vercel.app

# Node environment
NODE_ENV=production

# TLS verification (set to 0 only for self-signed certs in dev)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Timezone
TZ=UTC
NEXT_PUBLIC_TZ=UTC

# =============================================================================
# Logging & Monitoring
# =============================================================================

LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DIR=./logs
LOG_RETENTION_DAYS=30

# Splunk HEC (HTTP Event Collector) for application logging
SPLUNK_HEC_ENABLED=false
# SPLUNK_HEC_URL=https://your-splunk-instance:8088/services/collector
# SPLUNK_HEC_TOKEN=your-hec-token-here
# SPLUNK_HEC_INDEX=main
# SPLUNK_HEC_SOURCE=dashpub
# SPLUNK_HEC_SOURCETYPE=dashpub:app:logs

# =============================================================================
# Custom Visualizations & Dependencies
# =============================================================================

# Path to custom visualization components
# DASHPUB_CUSTOM_VIZ_PATH=./custom_components

# Additional npm dependencies to install (JSON array)
# DASHPUB_CUSTOM_DEPS='[{"some-package": "^1.0.0"}]'

# Skip Puppeteer browser download (set true if screenshots not needed)
PUPPETEER_SKIP_DOWNLOAD=true
